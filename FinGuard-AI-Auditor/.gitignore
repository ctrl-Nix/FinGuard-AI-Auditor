# ─────────────────────────────────────────────────────────────
# FinGuard 3.0 — Git Ignore Rules
# ─────────────────────────────────────────────────────────────

# ── Secret / environment files ────────────────────────────────
.env
.env.*
*.secret
*.key
*.pem
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.python-version
.venv/
venv/
ENV/
env/
pyvenv.cfg
backend/.venv/
backend/venv/

# ── Node.js ───────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
pnpm-lock.yaml
yarn.lock
frontend/node_modules/

# ── Build outputs ─────────────────────────────────────────────
/frontend/dist/
/frontend/.vite/
/dist/
/build/
*.egg-info/
*.egg

# ── Test / coverage ───────────────────────────────────────────
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# ── Generated reports (never commit these) ────────────────────
finguard_report.pdf
finguard_audit_result.json
backend/finguard_report.pdf

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/

# ── Editors ───────────────────────────────────────────────────
.vscode/
.idea/
*.iml
*~
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Firebase ──────────────────────────────────────────────────
backend/firebase-service-account*.json

# ── Misc ──────────────────────────────────────────────────────
backend/dataset/
backend/*.pth
*pptx*
